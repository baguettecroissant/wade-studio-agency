---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import { Flame, MapPin, Calendar, BarChart3, ArrowRight, ShieldCheck, Sparkles, AlertCircle } from '@lucide/astro';
---

<Layout 
  title="Solution Chauffage & Pompe à Chaleur (PAC) - Wade Studio" 
  description="Exclusivité locale pour chauffagistes RGE. Obtenez 100% de demandes d'installation de pompes à chaleur qualifiées et exclusives dans votre département."
>
  <div class="py-16 lg:py-24 relative overflow-hidden bg-[#FBF9F6]/50 font-sans">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,rgba(15,23,42,0.02)_1px,transparent_1px),linear-gradient(to_bottom,rgba(15,23,42,0.02)_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_100%,#000_70%,transparent_100%)] pointer-events-none z-0"></div>
    
    <div class="container mx-auto max-w-6xl px-6 relative z-10">
      
      <!-- Breadcrumb -->
      <nav class="flex items-center space-x-2 text-xs text-text-secondary mb-8">
        <a href="/" class="hover:text-slate-900 transition-colors">Accueil</a>
        <span>/</span>
        <span class="text-slate-900">Solutions</span>
        <span>/</span>
        <span class="text-primary-neon font-semibold">Chauffage & PAC</span>
      </nav>

      <!-- Main Columns -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
        
        <!-- Left: Copy -->
        <div class="lg:col-span-7 space-y-6">
          <div class="inline-flex items-center space-x-2 rounded-full border border-primary-neon/15 bg-primary-neon/5 px-3 py-1">
            <Flame class="h-4 w-4 text-primary-neon animate-pulse" />
            <span class="font-mono text-[10px] font-bold text-primary-neon uppercase tracking-wider">Chauffagistes & Artisans RGE</span>
          </div>
          
          <h1 class="font-heading text-4xl font-normal text-slate-900 sm:text-5xl leading-tight">
            Dominez votre marché local avec des <span class="gradient-text-editorial">leads chauffage & PAC exclusifs</span>
          </h1>
          
          <p class="text-sm text-text-secondary leading-relaxed max-w-xl">
            Ne perdez plus votre temps à appeler des fiches revendues à dix concurrents à la fois. Wade Studio déploie des portails locaux exclusifs pour vous positionner en position n°1 sur votre région.
          </p>

          <div class="grid grid-cols-2 gap-6 pt-4 border-t border-slate-200/80">
            <div>
              <span class="block text-2xl font-mono font-bold text-slate-900">+95 leads</span>
              <span class="text-xs text-text-secondary mt-1 block">Volume moyen sur 3 mois</span>
            </div>
            <div>
              <span class="block text-2xl font-mono font-bold text-emerald-600">+72k €</span>
              <span class="text-xs text-text-secondary mt-1 block">CA Partenaire moyen</span>
            </div>
          </div>
        </div>

        <!-- Right: Vertical Story Video -->
        <div class="lg:col-span-5 flex justify-center">
          <div class="w-[280px] h-[480px] rounded-3xl overflow-hidden relative shadow-xl border border-slate-200/60 bg-slate-950">
            <video 
              autoplay 
              loop 
              muted 
              playsinline 
              poster="/images/artisan_chauffagiste.png"
              class="absolute inset-0 w-full h-full object-cover opacity-85"
            >
              <source src="https://assets.mixkit.co/videos/preview/mixkit-handyman-with-a-drill-screwing-something-41558-large.mp4" type="video/mp4" />
            </video>
            <!-- Overlays -->
            <div class="absolute inset-x-0 bottom-0 h-48 bg-gradient-to-t from-black/85 via-black/40 to-transparent pointer-events-none"></div>
            <div class="absolute inset-x-0 bottom-6 px-5 text-white">
              <span class="text-[9px] font-mono font-bold uppercase tracking-wider text-accent-violet">Démonstration Live</span>
              <h3 class="font-heading text-base font-bold text-white mt-1">Réseau Gironde (33)</h3>
              <p class="text-xs text-stone-200 mt-1 flex items-center space-x-1.5">
                <span class="h-1.5 w-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
                <span>+6 demandes aujourd'hui</span>
              </p>
            </div>
          </div>
        </div>

      </div>

    </div>
  </div>

  <!-- Detailed Case Study / Proof Section -->
  <section class="py-20 bg-white font-sans border-t border-slate-100">
    <div class="container mx-auto max-w-4xl px-6">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <h2 class="font-heading text-3xl font-normal text-slate-900">Preuve de performance en direct de la Gironde (33)</h2>
        <p class="text-xs text-text-secondary mt-3">Analyse des flux réels et rapports Google Search Console de notre portail partenaire.</p>
      </div>

      <!-- Case study details card -->
      <div class="glass-card-neon rounded-3xl border border-slate-200/60 p-6 md:p-10 shadow-sm">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center border-b border-slate-100 pb-6 mb-8 gap-4">
          <div class="flex items-center space-x-3.5">
            <div class="h-10 w-10 rounded-xl bg-primary-neon/5 border border-primary-neon/10 flex items-center justify-center text-primary-neon">
              <MapPin class="h-5 w-5" />
            </div>
            <div>
              <h3 class="font-heading text-lg font-bold text-slate-900 leading-none">Gironde (33)</h3>
              <span class="text-xs text-text-secondary mt-1 block">Chauffage & Pompe à Chaleur</span>
            </div>
          </div>
          <span class="bg-emerald-500/5 border border-emerald-500/10 px-3 py-1 rounded-full text-[9px] font-mono font-bold text-emerald-700 uppercase tracking-wider">Actif / Monopole</span>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
          <div class="space-y-4">
            <h4 class="font-heading text-base font-bold text-slate-900">Le partenariat Wade Studio :</h4>
            <ul class="space-y-3 text-xs text-text-secondary">
              <li class="flex items-start space-x-2">
                <span class="h-1.5 w-1.5 rounded-full bg-primary-neon shrink-0 mt-1.5"></span>
                <span>Position 1.4 moyenne sur Google pour 'Installateur PAC Bordeaux', 'Chauffage RGE Gironde'.</span>
              </li>
              <li class="flex items-start space-x-2">
                <span class="h-1.5 w-1.5 rounded-full bg-primary-neon shrink-0 mt-1.5"></span>
                <span>Fiches qualifiées exclusives avec mode de chauffage actuel, surface de la maison et statut de propriété.</span>
              </li>
              <li class="flex items-start space-x-2">
                <span class="h-1.5 w-1.5 rounded-full bg-primary-neon shrink-0 mt-1.5"></span>
                <span>Taux de conversion de lead en chantier signé moyen de 48% sur notre réseau Gironde.</span>
              </li>
            </ul>
          </div>

          <!-- GSC Graphic -->
          <div class="relative rounded-2xl border border-slate-200 overflow-hidden bg-slate-50/80 p-4 h-44 flex flex-col justify-between shadow-inner">
            <div class="flex justify-between items-center z-10 text-[9px] font-mono text-text-secondary">
              <span class="flex items-center space-x-1"><BarChart3 class="h-3.5 w-3.5 text-primary-neon" /><span>Google Search Console</span></span>
              <span>3 Mois</span>
            </div>
            <div class="absolute inset-x-0 bottom-4 h-28 px-2 select-none">
              <svg viewBox="0 0 300 100" class="w-full h-full" preserveAspectRatio="none">
                <defs>
                  <linearGradient id="chartGradPAC" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="#0B3C2E" stop-opacity="0.1" />
                    <stop offset="100%" stop-color="#0B3C2E" stop-opacity="0.0" />
                  </linearGradient>
                </defs>
                <path d="M0,88 Q30,78 60,65 T120,55 T180,35 T240,20 T300,8 L300,100 L0,100 Z" fill="url(#chartGradPAC)" />
                <path d="M0,88 Q30,78 60,65 T120,55 T180,35 T240,20 T300,8" fill="none" stroke="#0B3C2E" stroke-width="2" />
                <circle cx="300" cy="8" r="4" fill="#0B3C2E" />
              </svg>
            </div>
            <div class="absolute inset-0 bg-white/10 backdrop-blur-[1px] flex items-center justify-center rounded-2xl m-1.5">
              <div class="bg-white border border-slate-200 px-3 py-1 rounded-lg shadow-sm text-[9px] font-mono text-text-secondary">
                Données de clics organiques vérifiées
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section (SEO Long-Tail) -->
  <section class="py-20 bg-slate-50 border-t border-slate-100 font-sans">
    <div class="container mx-auto max-w-3xl px-6">
      <h2 class="font-heading text-2xl font-normal text-slate-900 text-center mb-12">Questions fréquentes - Pompe à Chaleur (PAC)</h2>
      <div class="space-y-6">
        <div class="bg-white border border-slate-200/60 p-5 rounded-xl">
          <h3 class="font-heading text-sm font-bold text-slate-900">Quelles sont les conditions pour obtenir MaPrimeRénov' pour une PAC ?</h3>
          <p class="text-xs text-text-secondary mt-2">
            L'installation d'une pompe à chaleur air-eau ou d'une chaudière biomasse doit être effectuée par un professionnel certifié RGE (Reconnu Garant de l'Environnement). L'aide dépend des revenus du foyer et du gain d'efficacité énergétique.
          </p>
        </div>
        <div class="bg-white border border-slate-200/60 p-5 rounded-xl">
          <h3 class="font-heading text-sm font-bold text-slate-900">Comment qualifiez-vous les demandes de chauffage ?</h3>
          <p class="text-xs text-text-secondary mt-2">
            Notre formulaire vérifie le système de chauffage actuel (fioul, gaz, électrique), la superficie de la maison, l'isolation générale, et les coordonnées complètes du client.
          </p>
        </div>
        <div class="bg-white border border-slate-200/60 p-5 rounded-xl">
          <h3 class="font-heading text-sm font-bold text-slate-900">Pourquoi l'exclusivité Wade Studio améliore-t-elle le taux de signature ?</h3>
          <p class="text-xs text-text-secondary mt-2">
            Contrairement aux plateformes classiques qui revendent les fiches à 3 ou 5 artisans, nos leads sont 100% exclusifs. Le prospect n'est en relation qu'avec vous, éliminant la concurrence directe et la guerre des prix.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Semantic Cocoon Cross-linking Section -->
  <section class="py-12 bg-white border-t border-slate-100 font-sans">
    <div class="container mx-auto max-w-4xl px-6">
      <h3 class="font-heading text-xs font-bold text-[#9A784E] uppercase tracking-wider mb-6 text-center">Solutions connexes suggérées :</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <a href="/solutions/climatisation" class="border border-slate-200/60 p-4 rounded-xl flex items-center justify-between hover:border-primary-neon/20 hover:shadow-sm transition-all group">
          <div>
            <span class="font-heading text-xs font-bold text-slate-900">Climatisation Réversible</span>
            <span class="block text-[10px] text-text-secondary mt-0.5">Pour les projets de confort thermique air-air été/hiver</span>
          </div>
          <ArrowRight class="h-4 w-4 text-text-secondary group-hover:text-primary-neon transition-colors" />
        </a>
        <a href="/solutions/renovation" class="border border-slate-200/60 p-4 rounded-xl flex items-center justify-between hover:border-primary-neon/20 hover:shadow-sm transition-all group">
          <div>
            <span class="font-heading text-xs font-bold text-slate-900">Rénovation Globale & RGE</span>
            <span class="block text-[10px] text-text-secondary mt-0.5">Combinez chauffage et isolation pour maximiser les subventions</span>
          </div>
          <ArrowRight class="h-4 w-4 text-text-secondary group-hover:text-primary-neon transition-colors" />
        </a>
      </div>
      <div class="text-center mt-10">
        <a href="/solutions" class="text-xs text-primary-neon font-bold hover:underline">
          ← Retourner au répertoire des solutions
        </a>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 bg-[#FBF9F6]/50 border-t border-slate-100 font-sans">
    <div class="container mx-auto max-w-3xl px-6 text-center">
      <h3 class="font-heading text-2xl font-normal text-slate-900">Obtenez l'exclusivité des leads Chauffage & PAC sur votre secteur</h3>
      <p class="font-sans text-xs text-text-secondary mt-2">Nous ne prenons qu'un seul chauffagiste RGE partenaire par département. Rejoignez notre réseau avant votre concurrent.</p>
      <div class="mt-8">
        <a href="/candidature" class="inline-flex h-12 items-center justify-center rounded-xl bg-primary-neon hover:bg-primary-neon/90 hover:scale-[1.01] active:scale-[0.99] px-6 text-sm font-bold text-white transition-all duration-200 shadow-md">
          Vérifier la disponibilité de mon secteur <ArrowRight class="ml-2 h-4 w-4" />
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
