---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import { departments } from '../../data/departments.js';
import { niches } from '../../data/niches.js';
import { Briefcase, MapPin, ChevronRight, Lock } from '@lucide/astro';
---

<Layout 
  title="Recrutement Partenaires Artisans - Exclusivité Locale - Wade Studio" 
  description="Rejoignez le réseau Wade Studio. Choisissez votre département et votre spécialité pour bloquer votre monopole territorial d'acquisition de leads de chantiers RGE."
>
  <!-- Header -->
  <section class="py-16 lg:py-20 bg-[#FBF9F6]/80 border-b border-slate-100 font-sans">
    <div class="container mx-auto max-w-4xl px-6 text-center">
      <span class="font-mono text-[10px] font-semibold text-primary-neon uppercase tracking-wider bg-primary-neon/5 border border-primary-neon/10 px-3 py-1 rounded-full">
        Partenariat B2B National & Local
      </span>
      <h1 class="font-heading text-4xl font-normal text-slate-900 sm:text-5xl mt-6 leading-tight">
        Sécurisez l'Exclusivité de <span class="gradient-text-editorial">Votre Département</span>
      </h1>
      <p class="font-sans text-sm text-text-secondary mt-4 max-w-2xl mx-auto leading-relaxed">
        Nous créons des infrastructures d'acquisition exclusives pour les professionnels du bâtiment. Sélectionnez votre métier et votre département ci-dessous pour vérifier la disponibilité de votre secteur.
      </p>
      <div class="mt-4 inline-flex items-center space-x-2 text-[11px] font-mono text-text-secondary bg-[#FBF9F6] border border-slate-200 px-3.5 py-1.5 rounded-xl">
        <Lock class="h-3.5 w-3.5 text-[#9A784E]" />
        <span>Règle stricte : un seul artisan par zone géographique et par spécialité.</span>
      </div>
    </div>
  </section>

  <!-- Directory Section -->
  <section class="py-16 bg-white font-sans">
    <div class="container mx-auto max-w-7xl px-6">
      
      <!-- Niches Selector & Grid Directory -->
      <div class="space-y-16">
        {niches.map((niche) => {
          // Calculate total departments listed
          return (
            <div class="space-y-6 border-b border-slate-100 pb-12 last:border-0 last:pb-0">
              <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                <div class="space-y-1">
                  <h2 class="font-heading text-2xl font-normal text-slate-900 flex items-center space-x-2.5">
                    <span class="inline-block h-2 w-2 rounded-full bg-primary-neon"></span>
                    <span>Leads {niche.label}</span>
                  </h2>
                  <p class="text-xs text-text-secondary max-w-xl">{niche.description}</p>
                </div>
                <div class="shrink-0 text-left sm:text-right">
                  <span class="text-[10px] font-mono text-text-secondary block">Statut du réseau</span>
                  <span class="inline-flex items-center text-[10px] font-mono font-bold text-success-green bg-success-green/5 border border-success-green/20 px-2 py-0.5 rounded-md mt-1">
                    Candidatures Ouvertes (96 zones)
                  </span>
                </div>
              </div>

              <!-- 4-column Grid of Departments -->
              <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-3 pt-4">
                {departments.map((dept) => (
                  <a 
                    href={`/partenaires/${niche.slug}/${dept.slug}`}
                    class="group flex items-center justify-between p-2.5 rounded-xl border border-slate-100 bg-[#FBF9F6]/20 hover:bg-slate-50 hover:border-slate-300 transition-all duration-150"
                  >
                    <span class="text-xs text-text-secondary group-hover:text-slate-900 font-medium transition-colors">
                      <strong class="font-mono text-slate-900 group-hover:text-primary-neon transition-colors mr-1">{dept.code}</strong> 
                      {dept.name}
                    </span>
                    <ChevronRight class="h-3 w-3 text-text-secondary opacity-0 group-hover:opacity-100 transition-all duration-150 shrink-0" />
                  </a>
                ))}
              </div>
            </div>
          );
        })}
      </div>

    </div>
  </section>

  <!-- Footer -->
  <Footer />
</Layout>
