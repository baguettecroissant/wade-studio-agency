---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Comparison from '../components/Comparison.astro';
import System from '../components/System.astro';
import StoryCards from '../components/StoryCards.astro';
import RoiSimulator from '../components/RoiSimulator.astro';
import CaseStudies from '../components/CaseStudies.astro';
import Faq from '../components/Faq.astro';
import AvailabilityForm from '../components/AvailabilityForm.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
	<!-- Hero Section -->
	<Hero />

	<!-- Core Problem / Comparison Grid Section -->
	<Comparison />

	<!-- Stepper / System Section -->
	<System />

	<!-- Live Stories Section -->
	<StoryCards />

	<!-- ROI Simulator Section -->
	<RoiSimulator />

	<!-- Case Studies Section -->
	<CaseStudies />

	<!-- FAQ Section -->
	<Faq />

	<!-- Availability Form Section -->
	<AvailabilityForm />

	<!-- Footer Section -->
	<Footer />
</Layout>
