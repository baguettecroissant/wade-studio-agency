---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import VideoExplainer from '../components/VideoExplainer.astro';
import Comparison from '../components/Comparison.astro';
import System from '../components/System.astro';
import StoryCards from '../components/StoryCards.astro';
import RoiSimulator from '../components/RoiSimulator.astro';
import CaseStudies from '../components/CaseStudies.astro';
import Faq from '../components/Faq.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
	<!-- Hero Section -->
	<Hero />

	<!-- Video Explainer Section -->
	<VideoExplainer />

	<!-- Core Problem / Comparison Grid Section -->
	<Comparison />

	<!-- Stepper / System Section -->
	<System />

	<!-- Live Stories Section -->
	<StoryCards />

	<!-- ROI Simulator Section -->
	<RoiSimulator />

	<!-- Case Studies Section -->
	<CaseStudies />

	<!-- FAQ Section -->
	<Faq />

	<!-- Final CTA Section -->
	<section class="py-20 bg-[#FBF9F6]/50 border-t border-slate-100 font-sans text-center">
		<div class="container mx-auto max-w-3xl px-6">
			<span class="font-mono text-[10px] font-bold text-accent-violet uppercase tracking-wider">Monopole Territorial</span>
			<h2 class="font-heading text-3xl font-normal text-slate-900 mt-4 leading-tight">Prêt à sécuriser l'exclusivité de votre secteur ?</h2>
			<p class="text-sm text-text-secondary mt-3 max-w-lg mx-auto">Nous ne travaillons qu'avec un seul artisan partenaire par département et par métier. Ne laissez pas votre concurrent prendre les devants.</p>
			<div class="mt-8 flex flex-col items-center space-y-3">
				<a href="/candidature" class="inline-flex h-12 items-center justify-center rounded-xl bg-primary-neon px-8 text-sm font-bold text-white shadow-md hover:scale-[1.02] active:scale-[0.98] transition-all duration-200">
					Tester mon éligibilité en 2 minutes
				</a>
				<a href="/partenaires" class="text-xs font-semibold text-text-secondary hover:text-primary-neon hover:underline">
					Ou consulter les départements encore disponibles →
				</a>
			</div>
		</div>
	</section>

	<!-- Footer Section -->
	<Footer />
</Layout>
