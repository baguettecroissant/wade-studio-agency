---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import { caseStudies } from '../../data/caseStudies.js';
import { 
  ArrowLeft, ShieldCheck, TrendingUp, Sparkles, MapPin, 
  Calendar, CheckCircle2, User, AlertCircle, FileText, ChevronRight
} from '@lucide/astro';

// Generate static paths for the 4 case studies
export function getStaticPaths() {
  return caseStudies.map(cs => ({
    params: { slug: cs.slug },
    props: { cs }
  }));
}

const { cs } = Astro.props;

// Calculate SVG path points dynamically for the chart (viewBox 0 0 500 200)
const width = 500;
const height = 200;
const padding = 20;

const pointsCount = cs.chartPoints.length;
const maxVal = Math.max(...cs.chartPoints);
const minVal = Math.min(...cs.chartPoints);

const svgPoints = cs.chartPoints.map((val, idx) => {
  const x = padding + (idx * (width - padding * 2)) / (pointsCount - 1);
  // Map value to Y (invert since SVG Y=0 is top)
  const y = height - padding - ((val - minVal * 0.5) * (height - padding * 2)) / (maxVal - minVal * 0.5 || 1);
  return { x, y, value: val };
});

// Construct SVG path string (curved using Catmull-Rom or cubic bezier, or simple line path)
// A simple line path is extremely robust
const pathD = svgPoints.map((pt, idx) => `${idx === 0 ? 'M' : 'L'}${pt.x.toFixed(1)},${pt.y.toFixed(1)}`).join(' ');
const areaD = `${pathD} L${svgPoints[pointsCount - 1].x.toFixed(1)},${height - padding} L${svgPoints[0].x.toFixed(1)},${height - padding} Z`;
---

<Layout 
  title={`${cs.title} - Wade Studio`} 
  description={`Découvrez comment cet artisan ${cs.partnerLabel.toLowerCase()} en ${cs.locationLabel} a obtenu son monopole avec Wade Studio. Résultats et chiffres réels.`}
>
  <!-- Breadcrumbs -->
  <div class="bg-[#FBF9F6] border-b border-slate-100 py-3.5 font-sans">
    <div class="container mx-auto max-w-7xl px-6">
      <div class="flex items-center space-x-2 text-[10px] font-mono text-text-secondary uppercase tracking-wider">
        <a href="/" class="hover:text-slate-900 transition-colors">Accueil</a>
        <ChevronRight class="h-3 w-3" />
        <a href="/#case-studies" class="hover:text-slate-900 transition-colors">Études de Cas</a>
        <ChevronRight class="h-3 w-3" />
        <span class="text-slate-900 font-bold">{cs.nicheLabel} ({cs.locationLabel})</span>
      </div>
    </div>
  </div>

  <!-- Hero Header -->
  <section class="py-16 lg:py-24 relative overflow-hidden bg-[#FBF9F6]/80 font-sans border-b border-slate-100">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,rgba(15,23,42,0.01)_1px,transparent_1px),linear-gradient(to_bottom,rgba(15,23,42,0.01)_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_100%,#000_70%,transparent_100%)] pointer-events-none z-0"></div>
    
    <div class="container mx-auto max-w-5xl px-6 relative z-10">
      <div class="space-y-6">
        <a href="/#case-studies" class="inline-flex items-center text-xs font-semibold text-text-secondary hover:text-primary-neon transition-colors duration-150">
          <ArrowLeft class="h-4 w-4 mr-2" />
          Retour aux résultats
        </a>

        <div class="flex flex-wrap gap-2 items-center">
          <span class="inline-flex items-center space-x-1.5 font-mono text-[10px] font-bold text-primary-neon uppercase tracking-wider bg-primary-neon/5 border border-primary-neon/10 px-3 py-1 rounded-full">
            <MapPin class="h-3.5 w-3.5" />
            <span>Exclusivité - {cs.locationLabel}</span>
          </span>
          <span class="inline-flex items-center space-x-1.5 font-mono text-[10px] font-bold text-accent-violet uppercase tracking-wider bg-[#9A784E]/5 border border-[#9A784E]/10 px-3 py-1 rounded-full">
            <Sparkles class="h-3.5 w-3.5" />
            <span>Position Google : {cs.seoPosition}</span>
          </span>
        </div>
        
        <h1 class="font-heading text-3xl font-normal text-slate-900 sm:text-4xl lg:text-5xl max-w-4xl leading-tight">
          {cs.title}
        </h1>
        
        <p class="font-sans text-sm md:text-base text-text-secondary leading-relaxed max-w-2xl">
          Découvrez en détail l'infrastructure, l'analyse financière et la méthode de référencement mise en place par Wade Studio pour assurer le succès de notre partenaire {cs.partnerName}.
        </p>
      </div>
    </div>
  </section>

  <!-- Metrics Dashboard & GSC Chart -->
  <section class="py-16 bg-white font-sans border-b border-slate-100">
    <div class="container mx-auto max-w-5xl px-6">
      
      <!-- Key KPI Cards -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-12">
        <div class="bg-[#FBF9F6]/60 border border-slate-200/60 p-5 rounded-2xl shadow-sm text-center relative overflow-hidden group">
          <span class="text-[9px] font-mono text-text-secondary uppercase tracking-wider font-semibold block">Chiffre d'Affaires</span>
          <strong class="font-heading text-2xl lg:text-3xl font-bold text-primary-neon block mt-1.5">{cs.metricRevenue}</strong>
          <span class="text-[10px] text-text-secondary mt-1 block uppercase font-mono">{cs.metricRevenueSub}</span>
        </div>
        
        <div class="bg-[#FBF9F6]/60 border border-slate-200/60 p-5 rounded-2xl shadow-sm text-center relative overflow-hidden group">
          <span class="text-[9px] font-mono text-text-secondary uppercase tracking-wider font-semibold block">Volume Demandes</span>
          <strong class="font-heading text-2xl lg:text-3xl font-bold text-slate-900 block mt-1.5">{cs.metricLeads}</strong>
          <span class="text-[10px] text-text-secondary mt-1 block uppercase font-mono">{cs.metricLeadsSub}</span>
        </div>

        <div class="bg-[#FBF9F6]/60 border border-slate-200/60 p-5 rounded-2xl shadow-sm text-center relative overflow-hidden group">
          <span class="text-[9px] font-mono text-text-secondary uppercase tracking-wider font-semibold block">Taux de Signature</span>
          <strong class="font-heading text-2xl lg:text-3xl font-bold text-accent-violet block mt-1.5">{cs.metricClosing}</strong>
          <span class="text-[10px] text-text-secondary mt-1 block uppercase font-mono">{cs.metricClosingSub}</span>
        </div>

        <div class="bg-[#FBF9F6]/60 border border-slate-200/60 p-5 rounded-2xl shadow-sm text-center relative overflow-hidden group">
          <span class="text-[9px] font-mono text-text-secondary uppercase tracking-wider font-semibold block">Bénéfice Net CA</span>
          <strong class="font-heading text-2xl lg:text-3xl font-bold text-emerald-700 block mt-1.5">{cs.metricRoi}</strong>
          <span class="text-[10px] text-text-secondary mt-1 block uppercase font-mono">{cs.metricRoiSub}</span>
        </div>
      </div>

      <!-- Layout Grid: Left GSC Chart / Right Financial Details -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-stretch">
        
        <!-- Left: GSC Organic Clicks SVG Chart -->
        <div class="lg:col-span-7 bg-white border border-slate-200 rounded-3xl p-6 md:p-8 shadow-sm flex flex-col justify-between">
          <div>
            <div class="flex items-center justify-between border-b border-slate-100 pb-4 mb-6">
              <span class="text-xs font-mono font-semibold text-text-secondary uppercase tracking-wider flex items-center space-x-2">
                <TrendingUp class="h-4 w-4 text-primary-neon animate-pulse" />
                <span>Google Search Console (Clics Organiques Locaux)</span>
              </span>
              <span class="text-[10px] font-mono text-primary-neon bg-primary-neon/5 px-2 py-0.5 border border-primary-neon/10 rounded font-semibold">{cs.metricPeriod}</span>
            </div>
            
            <p class="text-xs text-text-secondary leading-relaxed mb-6">
              Cette courbe présente le flux réel de clics et de prospects arrivant sur nos portails locaux. L'augmentation constante correspond à l'indexation et au positionnement Google de nos pages.
            </p>
          </div>

          <!-- SVG Vector Graph -->
          <div class="relative h-60 w-full bg-slate-50/50 border border-slate-200/60 rounded-2xl p-4 shadow-inner">
            <svg viewBox={`0 0 ${width} ${height}`} class="w-full h-full overflow-visible" preserveAspectRatio="none">
              <defs>
                <linearGradient id="chartGrad" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%" stop-color="#0B3C2E" stop-opacity="0.25" />
                  <stop offset="100%" stop-color="#0B3C2E" stop-opacity="0.0" />
                </linearGradient>
              </defs>
              
              <!-- Grid Lines -->
              <line x1="20" y1="180" x2="480" y2="180" stroke="#E2E8F0" stroke-width="1" stroke-dasharray="4" />
              <line x1="20" y1="110" x2="480" y2="110" stroke="#E2E8F0" stroke-width="1" stroke-dasharray="4" />
              <line x1="20" y1="40" x2="480" y2="40" stroke="#E2E8F0" stroke-width="1" stroke-dasharray="4" />
              
              <!-- Shaded Area -->
              <path d={areaD} fill="url(#chartGrad)" />
              
              <!-- Curved Line -->
              <path d={pathD} fill="none" stroke="#0B3C2E" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
              
              <!-- Interactive Circles / Markers -->
              {svgPoints.map((pt) => (
                <g class="group/dot cursor-pointer">
                  <circle cx={pt.x} cy={pt.y} r="6" fill="#0B3C2E" />
                  <circle cx={pt.x} cy={pt.y} r="3" fill="#FFFFFF" />
                  <text x={pt.x} y={pt.y - 12} text-anchor="middle" font-family="monospace" font-size="10" font-weight="bold" fill="#0B3C2E">
                    {pt.value}
                  </text>
                </g>
              ))}
            </svg>

            <!-- Chart X labels -->
            <div class="flex justify-between px-3 mt-3 text-[9px] font-mono text-text-secondary">
              {cs.chartLabels.map(l => <span>{l}</span>)}
            </div>
          </div>
        </div>

        <!-- Right: Business Financial Model -->
        <div class="lg:col-span-5 bg-gradient-to-br from-[#0B3C2E] to-[#1C1917] rounded-3xl p-6 md:p-8 text-white flex flex-col justify-between shadow-md">
          <div>
            <div class="flex items-center space-x-2.5 border-b border-white/10 pb-4 mb-6">
              <FileText class="h-5 w-5 text-accent-violet" />
              <h3 class="font-heading text-lg font-bold text-white">Analyse Financière Réelle</h3>
            </div>

            <p class="text-xs text-stone-200 leading-relaxed mb-6">
              Calcul de rentabilité basé sur l'investissement mensuel moyen en demandes exclusives et les contrats effectivement signés par {cs.partnerName}.
            </p>

            <ul class="space-y-4">
              <li class="flex justify-between items-center text-xs border-b border-white/5 pb-2.5">
                <span class="text-stone-300">Budget Mensuel Investi</span>
                <span class="font-mono text-white font-bold">{cs.financials.leadCost}</span>
              </li>
              <li class="flex justify-between items-center text-xs border-b border-white/5 pb-2.5">
                <span class="text-stone-300">Taux de signature moyen</span>
                <span class="font-mono text-white font-bold">{cs.financials.closingRate}</span>
              </li>
              <li class="flex justify-between items-center text-xs border-b border-white/5 pb-2.5">
                <span class="text-stone-300">Nombre de chantiers signés</span>
                <span class="font-mono text-[#9A784E] font-bold">{cs.financials.signedContracts}</span>
              </li>
              <li class="flex justify-between items-center text-xs border-b border-white/5 pb-2.5">
                <span class="text-stone-300">Panier moyen par chantier</span>
                <span class="font-mono text-white font-bold">{cs.financials.avgTicket}</span>
              </li>
              <li class="flex justify-between items-center text-xs pt-1.5">
                <span class="text-stone-300 font-bold">Chiffre d'affaires brut généré</span>
                <span class="font-mono text-emerald-400 font-black text-sm">{cs.financials.revenue}</span>
              </li>
            </ul>
          </div>

          <div class="mt-8 pt-5 border-t border-white/10 bg-white/5 p-4 rounded-xl flex items-center justify-between">
            <div>
              <span class="text-[9px] font-mono uppercase text-stone-300 tracking-wider">Bénéfice Net Estimé</span>
              <strong class="block text-lg font-heading font-black text-white leading-none mt-1">{cs.financials.netProfit}</strong>
            </div>
            <span class="text-[10px] font-mono font-bold bg-[#9A784E] px-2 py-1 rounded text-white uppercase tracking-wider">{cs.metricRoi} ROI</span>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Challenge vs Solution -->
  <section class="py-20 bg-slate-50 font-sans border-b border-slate-100">
    <div class="container mx-auto max-w-4xl px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        
        <!-- Challenge Card -->
        <div class="bg-white border border-slate-200 p-6 md:p-8 rounded-3xl shadow-sm">
          <span class="inline-flex items-center space-x-1.5 font-mono text-[9px] font-bold text-red-600 uppercase tracking-wider bg-red-500/5 border border-red-500/10 px-2.5 py-1 rounded-full">
            <AlertCircle class="h-3.5 w-3.5" />
            <span>Le Défi Commercial de {cs.partnerName}</span>
          </span>
          <h3 class="font-heading text-lg font-bold text-slate-900 mt-4 leading-snug">L'impasse des leads partagés classiques</h3>
          <p class="text-xs text-text-secondary leading-relaxed mt-3.5">
            {cs.challenge}
          </p>
        </div>

        <!-- Solution Card -->
        <div class="bg-white border border-[#0B3C2E]/25 p-6 md:p-8 rounded-3xl shadow-md">
          <span class="inline-flex items-center space-x-1.5 font-mono text-[9px] font-bold text-[#0B3C2E] uppercase tracking-wider bg-[#0B3C2E]/5 border border-[#0B3C2E]/10 px-2.5 py-1 rounded-full">
            <CheckCircle2 class="h-3.5 w-3.5" />
            <span>La Solution Exclusive Wade</span>
          </span>
          <h3 class="font-heading text-lg font-bold text-slate-900 mt-4 leading-snug">Réseau Local & Monopole de Secteur</h3>
          <p class="text-xs text-text-secondary leading-relaxed mt-3.5">
            {cs.solution}
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- Partner Testimonial -->
  <section class="py-20 bg-white font-sans border-b border-slate-100">
    <div class="container mx-auto max-w-3xl px-6 text-center">
      <div class="inline-flex items-center space-x-1 mb-6">
        <span class="text-[#9A784E] text-xl">★</span>
        <span class="text-[#9A784E] text-xl">★</span>
        <span class="text-[#9A784E] text-xl">★</span>
        <span class="text-[#9A784E] text-xl">★</span>
        <span class="text-[#9A784E] text-xl">★</span>
      </div>
      
      <blockquote class="font-sans text-base lg:text-lg text-text-secondary italic leading-relaxed">
        "{cs.testimonial}"
      </blockquote>
      
      <div class="mt-6 flex items-center justify-center space-x-3">
        <div class="h-10 w-10 rounded-full bg-[#0B3C2E] flex items-center justify-center text-white font-bold text-sm">
          <User class="h-5 w-5 text-white" />
        </div>
        <div class="text-left">
          <cite class="font-heading text-sm text-slate-900 not-italic font-bold block">{cs.partnerName}</cite>
          <span class="text-xs text-text-secondary block">{cs.partnerLabel} en {cs.locationLabel}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA section -->
  <section class="py-20 bg-[#FBF9F6]/50 font-sans text-center">
    <div class="container mx-auto max-w-3xl px-6">
      <span class="font-mono text-[10px] font-bold text-accent-violet uppercase tracking-wider">Opportunité de Monopole</span>
      <h2 class="font-heading text-3xl font-normal text-slate-900 mt-4 leading-tight">Obtenez l'exclusivité des demandes dans votre secteur</h2>
      <p class="text-sm text-text-secondary mt-3 max-w-lg mx-auto">Comme {cs.partnerName}, arrêtez de partager vos chantiers avec vos concurrents locaux. Postulez pour vérifier si votre département est libre.</p>
      <div class="mt-8">
        <a href={`/candidature?niche=${cs.nicheSlug}`} class="inline-flex h-12 items-center justify-center rounded-xl bg-primary-neon px-8 text-sm font-bold text-white shadow-md hover:scale-[1.02] active:scale-[0.98] transition-all duration-200">
          Tester mon éligibilité en {cs.locationLabel}
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
