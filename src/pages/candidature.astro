---
import Layout from '../layouts/Layout.astro';
import AvailabilityForm from '../components/AvailabilityForm.astro';
import Footer from '../components/Footer.astro';
---

<Layout 
  title="Candidature Exclusivité - Wade Studio" 
  description="Déterminez l'éligibilité de votre entreprise et réservez l'exclusivité de votre secteur pour recevoir nos leads de chantiers qualifiés."
>
  <div class="py-10 lg:py-16 relative">
    <!-- Subtle Background Grid -->
    <div class="absolute inset-0 bg-[linear-gradient(to_right,rgba(15,23,42,0.02)_1px,transparent_1px),linear-gradient(to_bottom,rgba(15,23,42,0.02)_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_40%,#000_70%,transparent_100%)] pointer-events-none z-0"></div>
    
    <div class="relative z-10">
      <AvailabilityForm />
    </div>
  </div>
  
  <Footer />
</Layout>
