---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import { articles } from '../../data/blog.js';

// Metadata for SEO
const title = "Le Blog B2B Wade Studio | Acquisition & SEO pour Artisans";
const description = "Guides et analyses stratégiques pour les professionnels du bâtiment : Rank & Rent, acquisition de leads exclusifs, optimisation SEO locale et calcul des marges.";

// Extract unique categories for filter tabs
const categories = ["all", ...new Set(articles.map(a => a.category))];
---

<Layout title={title} description={description}>
  <!-- Hero Header Section -->
  <section class="pt-28 pb-16 md:pt-36 md:pb-24 bg-[#FBF9F6] border-b border-slate-100">
    <div class="container mx-auto max-w-7xl px-6 text-center">
      <span class="font-mono text-[10px] font-bold text-accent-violet uppercase tracking-wider">Académie Wade Studio</span>
      <h1 class="font-heading text-4xl md:text-5xl font-normal text-slate-900 mt-4 max-w-3xl mx-auto leading-tight">
        L'acquisition client décryptée pour les <span class="italic font-normal">artisans ambitieux</span>
      </h1>
      <p class="font-sans text-sm text-text-secondary mt-4 max-w-xl mx-auto leading-relaxed">
        Rank & Rent, SEO local, marges commerciales... Pas de jargon, que des chiffres réels et des stratégies concrètes pour dominer votre secteur géographique.
      </p>

      <!-- Category Filter Tabs -->
      <div class="flex flex-wrap justify-center gap-2.5 mt-10" id="filters-container">
        <button 
          class="category-btn px-5 py-2.5 text-[11px] font-bold uppercase tracking-wider rounded-xl border border-slate-200/80 bg-white text-text-secondary hover:text-slate-950 hover:border-slate-400 transition-all duration-200 cursor-pointer active-tab" 
          data-category="all"
        >
          Tous les articles
        </button>
        <button 
          class="category-btn px-5 py-2.5 text-[11px] font-bold uppercase tracking-wider rounded-xl border border-slate-200/80 bg-white text-text-secondary hover:text-slate-950 hover:border-slate-400 transition-all duration-200 cursor-pointer" 
          data-category="Acquisition B2B"
        >
          Acquisition B2B
        </button>
        <button 
          class="category-btn px-5 py-2.5 text-[11px] font-bold uppercase tracking-wider rounded-xl border border-slate-200/80 bg-white text-text-secondary hover:text-slate-950 hover:border-slate-400 transition-all duration-200 cursor-pointer" 
          data-category="SEO & Rank & Rent"
        >
          Rank & Rent & SEO
        </button>
        <button 
          class="category-btn px-5 py-2.5 text-[11px] font-bold uppercase tracking-wider rounded-xl border border-slate-200/80 bg-white text-text-secondary hover:text-slate-950 hover:border-slate-400 transition-all duration-200 cursor-pointer" 
          data-category="SEO & Croissance"
        >
          SEO & Croissance
        </button>
      </div>
    </div>
  </section>

  <!-- Grid Section -->
  <section class="py-16 bg-[#FBF9F6] min-h-[400px]">
    <div class="container mx-auto max-w-7xl px-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8" id="articles-grid">
        {articles.map((article) => (
          <article 
            class="article-card group flex flex-col justify-between rounded-2xl border border-slate-200/80 bg-white p-6 shadow-sm hover:shadow-md hover:border-slate-300 transition-all duration-200" 
            data-category={article.category}
          >
            <div>
              <!-- Article Meta Info -->
              <div class="flex items-center justify-between text-[11px] text-text-secondary font-mono mb-4">
                <span class="px-2.5 py-1 rounded-full bg-[#0B3C2E]/5 text-[#0B3C2E] font-sans font-bold">
                  {article.category}
                </span>
                <span>{article.readTime} de lecture</span>
              </div>

              <!-- Illustration Visual Container -->
              <div class="relative w-full aspect-video rounded-xl bg-slate-50 overflow-hidden mb-5 border border-slate-100">
                <img 
                  src={article.coverImage} 
                  alt={article.title} 
                  class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-300"
                />
              </div>

              <!-- Title -->
              <h3 class="font-heading text-lg font-normal text-slate-900 group-hover:text-[#0B3C2E] transition-colors leading-snug">
                <a href={`/blog/${article.slug}`}>
                  {article.title}
                </a>
              </h3>

              <!-- Summary -->
              <p class="font-sans text-xs text-text-secondary mt-3 leading-relaxed">
                {article.summary}
              </p>
            </div>

            <!-- Card footer link -->
            <div class="mt-6 pt-4 border-t border-slate-100 flex items-center justify-between">
              <span class="text-[11px] text-text-secondary">{article.date}</span>
              <a 
                href={`/blog/${article.slug}`} 
                class="inline-flex items-center space-x-1 text-xs font-bold text-[#0B3C2E] group-hover:translate-x-1 transition-transform"
              >
                <span>Lire l'article</span>
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Newsletter / Sticky Footer B2B CTA -->
  <section class="py-16 bg-[#0B3C2E] text-white">
    <div class="container mx-auto max-w-4xl px-6 text-center">
      <h2 class="font-heading text-2xl md:text-3xl font-normal leading-tight">Vous souhaitez générer vos propres leads exclusifs ?</h2>
      <p class="text-sm text-white/80 max-w-md mx-auto mt-3">
        Découvrez si votre secteur est encore libre et comment nous pouvons y déployer votre propre infrastructure.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/candidature" class="inline-flex h-12 items-center justify-center rounded-xl bg-white px-8 text-sm font-bold text-[#0B3C2E] shadow-lg hover:bg-slate-50 transition-colors">
          Tester mon éligibilité localement
        </a>
        <a href="/methode" class="text-xs font-bold text-white/90 hover:text-white underline underline-offset-4">
          Découvrir notre méthodologie en détail
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  /* Active tab styling */
  .active-tab {
    background-color: #0B3C2E !important;
    color: #FFFFFF !important;
    border-color: #0B3C2E !important;
  }
</style>

<script>
  // Simple client-side category filtering
  document.addEventListener('DOMContentLoaded', () => {
    const buttons = document.querySelectorAll('.category-btn');
    const cards = document.querySelectorAll('.article-card');

    buttons.forEach(button => {
      button.addEventListener('click', () => {
        // Remove active class from all
        buttons.forEach(btn => btn.classList.remove('active-tab'));
        
        // Add active class to clicked button
        button.classList.add('active-tab');

        const selectedCategory = button.getAttribute('data-category');

        cards.forEach(card => {
          const cardCategory = card.getAttribute('data-category');
          if (selectedCategory === 'all' || cardCategory === selectedCategory) {
            card.classList.remove('hidden');
            card.classList.add('flex');
            // If Tailwind hidden/flex overrides:
            (card as HTMLElement).style.display = 'flex';
          } else {
            card.classList.remove('flex');
            card.classList.add('hidden');
            (card as HTMLElement).style.display = 'none';
          }
        });
      });
    });
  });
</script>
