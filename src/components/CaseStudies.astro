            </div>
            <div class="bg-slate-50 border border-slate-100 p-3.5 rounded-xl">
              <span class="text-[10px] font-mono text-text-secondary uppercase tracking-wider">CA Partenaire</span>
              <span class="block text-2xl font-mono font-bold text-success-green mt-1.5">+62 000 €</span>
              <span class="text-[10px] text-text-secondary mt-1 block">CA Facturé</span>
