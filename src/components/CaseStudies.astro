              <span class="block text-2xl font-mono font-bold text-success-green mt-1.5">52%</span>
              <span class="text-[10px] text-text-secondary mt-1 block">Moyenne constatée</span>
            </div>
          </div>

          <!-- Glowing GSC Chart Visual -->
          <div class="relative rounded-2xl border border-slate-200 overflow-hidden bg-slate-50/80 p-4 h-48 flex flex-col justify-between shadow-inner">
            <div class="flex justify-between items-center z-10">
              <span class="text-[10px] font-mono font-semibold text-text-secondary uppercase tracking-wider flex items-center space-x-1.5">
                <BarChart3 class="h-3.5 w-3.5 text-accent-violet" />
                <span>Google Search Console (Clics Organiques)</span>
              </span>
              <span class="text-[9px] font-mono text-accent-violet bg-accent-violet/5 px-2 py-0.5 rounded border border-accent-violet/10 font-semibold">4 Mois</span>
            </div>

            <!-- SVG Line Chart (Clean Bronze Line) -->
            <div class="absolute inset-x-0 bottom-4 h-32 select-none px-2">
