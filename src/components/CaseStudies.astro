---
// CaseStudies component
import { BarChart3, TrendingUp, Calendar, MapPin, Sparkles, Sun, Hammer } from '@lucide/astro';
---

<section id="case-studies" class="py-20 lg:py-32 bg-[#FBF9F6]/30 border-t border-slate-100 relative">
  
  <div class="container mx-auto max-w-7xl px-6 relative z-10">
    
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-20 lg:mb-28">
      <span class="font-mono text-[10px] font-semibold text-primary-neon uppercase tracking-wider bg-primary-neon/5 border border-primary-neon/10 px-3 py-1 rounded-full">
        Preuves de Performance
      </span>
      <h2 class="font-heading text-3xl font-normal text-slate-900 sm:text-4xl lg:text-5xl mt-6">
        Des résultats validés par <span class="gradient-text-editorial">les rapports Google</span>
      </h2>
      <p class="font-sans text-base lg:text-lg text-text-secondary mt-6 leading-relaxed">
        Nous masquons les noms de domaine précis pour protéger le monopole de nos partenaires et préserver notre positionnement SEO local.
      </p>
    </div>

    <!-- Case Studies Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 max-w-5xl mx-auto">
      
      <!-- Card 1: Toiture Alpes-Maritimes -->
      <div class="glass-card-neon rounded-3xl overflow-hidden border border-slate-200 shadow-sm flex flex-col justify-between group hover:border-primary-neon/30 transition-all duration-300">
        <div class="h-44 w-full overflow-hidden relative">
          <img src="/images/artisan_couvreur.png" alt="Artisan Couvreur Alpes-Maritimes" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
          <div class="absolute inset-0 bg-gradient-to-t from-white via-white/10 to-transparent"></div>
        </div>
        <div class="p-6 lg:p-8">
          
          <!-- Card Title & Metadata -->
          <div class="flex justify-between items-start mb-6">
            <div class="flex items-center space-x-3.5">
              <div class="h-10 w-10 rounded-xl bg-primary-neon/5 border border-primary-neon/10 flex items-center justify-center text-primary-neon">
                <MapPin class="h-5 w-5" />
              </div>
              <div>
                <h3 class="font-heading font-normal text-slate-900 text-lg">Toiture & Couverture</h3>
                <p class="text-xs text-text-secondary">Alpes-Maritimes (06)</p>
              </div>
            </div>
            <div class="flex items-center space-x-1.5 bg-success-green/10 border border-success-green/20 px-2.5 py-1 rounded-full">
              <span class="h-1.5 w-1.5 rounded-full bg-success-green"></span>
              <span class="font-mono text-[9px] text-success-green font-semibold uppercase tracking-wider">Actif</span>
            </div>
          </div>
          
          <!-- Key Metric Stats -->
          <div class="grid grid-cols-2 gap-4 mb-8">
            <div class="bg-slate-50 border border-slate-100 p-3.5 rounded-xl">
              <span class="text-[10px] font-mono text-text-secondary uppercase tracking-wider">Leads qualifiés</span>
              <span class="block text-2xl font-mono font-bold text-slate-900 mt-1.5">+120</span>
              <span class="text-[10px] text-primary-neon mt-1 block font-medium">sur 3 mois</span>
            </div>
            <div class="bg-slate-50 border border-slate-100 p-3.5 rounded-xl">
              <span class="text-[10px] font-mono text-text-secondary uppercase tracking-wider">CA Partenaire</span>
              <span class="block text-2xl font-mono font-bold text-success-green mt-1.5">+84 000 €</span>
              <span class="text-[10px] text-text-secondary mt-1 block">CA Facturé</span>
            </div>
          </div>

          <!-- Glowing GSC Chart Visual -->
          <div class="relative rounded-2xl border border-slate-200 overflow-hidden bg-slate-50/80 p-4 h-48 flex flex-col justify-between shadow-inner">
            <div class="flex justify-between items-center z-10">
              <span class="text-[10px] font-mono font-semibold text-text-secondary uppercase tracking-wider flex items-center space-x-1.5">
                <BarChart3 class="h-3.5 w-3.5 text-primary-neon" />
                <span>Google Search Console (Clics Organiques)</span>
              </span>
              <span class="text-[9px] font-mono text-primary-neon bg-primary-neon/5 px-2 py-0.5 rounded border border-primary-neon/10 font-semibold">3 Mois</span>
            </div>

            <!-- SVG Line Chart (Clean Editorial Green) -->
            <div class="absolute inset-x-0 bottom-4 h-32 select-none px-2">
              <svg viewBox="0 0 300 100" class="w-full h-full" preserveAspectRatio="none">
                <defs>
                  <linearGradient id="chartGrad1" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="#0B3C2E" stop-opacity="0.1" />
                    <stop offset="100%" stop-color="#0B3C2E" stop-opacity="0.0" />
                  </linearGradient>
                </defs>
                <path d="M0,90 Q30,85 60,75 T120,60 T180,45 T240,25 T300,10 L300,100 L0,100 Z" fill="url(#chartGrad1)" />
                <path d="M0,90 Q30,85 60,75 T120,60 T180,45 T240,25 T300,10" fill="none" stroke="#0B3C2E" stroke-width="2" stroke-linecap="round" />
                <circle cx="300" cy="10" r="4" fill="#0B3C2E" />
                <circle cx="300" cy="10" r="2.5" fill="#FFFFFF" />
              </svg>
            </div>

            <!-- Absolute overlay showing chart is anonymized -->
            <div class="absolute inset-0 bg-white/10 backdrop-blur-[1px] flex items-center justify-center border border-white/5 rounded-2xl m-2">
              <div class="bg-white/95 border border-slate-200 px-3.5 py-1.5 rounded-lg flex items-center space-x-1.5 shadow-sm">
                <span class="h-1.5 w-1.5 rounded-full bg-primary-neon"></span>
                <span class="font-mono text-[9px] font-semibold text-text-secondary uppercase tracking-wider">Flux Réel Partenaire</span>
              </div>
            </div>
          </div>
          
        </div>
        
        <div class="px-6 py-4 lg:px-8 lg:py-5 border-t border-slate-100 bg-slate-50/50 flex items-center justify-between text-xs text-text-secondary">
          <span class="flex items-center space-x-1.5">
            <Calendar class="h-3.5 w-3.5 text-primary-neon" />
            <span>Mise en ligne : Mars 2026</span>
          </span>
          <span class="text-slate-900 font-medium flex items-center space-x-1">
            <Sparkles class="h-3.5 w-3.5 text-[#9A784E]" />
            <span>Position 1.3 Google</span>
          </span>
        </div>
      </div>

      <!-- Card 2: PAC Gironde -->
      <div class="glass-card-neon rounded-3xl overflow-hidden border border-slate-200 shadow-sm flex flex-col justify-between group hover:border-accent-violet/30 transition-all duration-300">
        <div class="h-44 w-full overflow-hidden relative">
          <img src="/images/artisan_chauffagiste.png" alt="Artisan Chauffagiste Gironde" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
          <div class="absolute inset-0 bg-gradient-to-t from-white via-white/10 to-transparent"></div>
        </div>
        <div class="p-6 lg:p-8">
          
          <!-- Card Title & Metadata -->
          <div class="flex justify-between items-start mb-6">
            <div class="flex items-center space-x-3.5">
              <div class="h-10 w-10 rounded-xl bg-accent-violet/5 border border-accent-violet/10 flex items-center justify-center text-accent-violet">
