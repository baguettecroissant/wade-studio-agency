              <span class="text-[10px] text-accent-violet mt-1 block font-medium">Exclusivité totale</span>
            </div>
            <div class="bg-slate-50 border border-slate-100 p-3.5 rounded-xl">
              <span class="text-[10px] font-mono text-text-secondary uppercase tracking-wider">Taux de signature</span>
              <span class="block text-2xl font-mono font-bold text-success-green mt-1.5">48%</span>
              <span class="text-[10px] text-text-secondary mt-1 block">Moyenne constatée</span>
            </div>
          </div>

          <!-- Glowing GSC Chart Visual -->
          <div class="relative rounded-2xl border border-slate-200 overflow-hidden bg-slate-50/80 p-4 h-48 flex flex-col justify-between shadow-inner">
            <div class="flex justify-between items-center z-10">
              <span class="text-[10px] font-mono font-semibold text-text-secondary uppercase tracking-wider flex items-center space-x-1.5">
                <BarChart3 class="h-3.5 w-3.5 text-accent-violet" />
                <span>Google Search Console (Clics Organiques)</span>
              </span>
              <span class="text-[9px] font-mono text-accent-violet bg-accent-violet/5 px-2 py-0.5 rounded border border-accent-violet/10 font-semibold">6 Mois</span>
            </div>

            <!-- SVG Line Chart (Clean Bronze Line) -->
            <div class="absolute inset-x-0 bottom-4 h-32 select-none px-2">
              <svg viewBox="0 0 300 100" class="w-full h-full" preserveAspectRatio="none">
                <defs>
                  <linearGradient id="chartGrad2" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="#9A784E" stop-opacity="0.1" />
                    <stop offset="100%" stop-color="#9A784E" stop-opacity="0.0" />
                  </linearGradient>
                </defs>
                <path d="M0,70 Q40,65 80,45 T160,35 T240,15 T300,8 L300,100 L0,100 Z" fill="url(#chartGrad2)" />
                <path d="M0,70 Q40,65 80,45 T160,35 T240,15 T300,8" fill="none" stroke="#9A784E" stroke-width="2" stroke-linecap="round" />
                <circle cx="300" cy="8" r="4" fill="#9A784E" />
                <circle cx="300" cy="8" r="2.5" fill="#FFFFFF" />
              </svg>
            </div>

            <!-- Absolute overlay showing chart is anonymized -->
            <div class="absolute inset-0 bg-white/10 backdrop-blur-[1px] flex items-center justify-center border border-white/5 rounded-2xl m-2">
              <div class="bg-white/95 border border-slate-200 px-3.5 py-1.5 rounded-lg flex items-center space-x-1.5 shadow-sm">
                <span class="h-1.5 w-1.5 rounded-full bg-accent-violet"></span>
                <span class="font-mono text-[9px] font-semibold text-text-secondary uppercase tracking-wider">Flux Réel Partenaire</span>
