---
// Footer Component
import { Heart } from '@lucide/astro';
---

<footer class="border-t border-slate-200 bg-slate-50 py-12 lg:py-16 relative">
  <!-- Background lights removed for clean editorial style -->
  <div class="container mx-auto max-w-7xl px-6 relative z-10">
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-5 gap-10 md:gap-8">
      
      <!-- Brand column -->
      <div class="sm:col-span-2 space-y-4">
        <a href="/" class="flex items-center space-x-2">
          <img src="/images/wade_studio_logo.png" alt="Wade Studio Logo" class="h-9 w-auto" />
        </a>
        <p class="font-sans text-xs text-text-secondary leading-relaxed max-w-sm mt-3">
          Nous concevons des infrastructures d'acquisition exclusives pour les professionnels du bâtiment et de l'énergie. Augmentez votre taux de signature, éliminez la concurrence.
        </p>
      </div>

      <!-- Links column 1 -->
      <div>
        <h4 class="font-heading text-xs font-bold text-slate-900 uppercase tracking-wider mb-4">Navigation</h4>
        <ul class="space-y-2.5 text-xs text-text-secondary">
          <li>
            <a href="/methode" class="hover:text-slate-900 transition-colors duration-150">Notre Méthode</a>
          </li>
          <li>
            <a href="/blog" class="hover:text-slate-900 transition-colors duration-150 font-medium">Blog B2B</a>
          </li>
          <li>
            <a href="/#roi-simulator" class="hover:text-slate-900 transition-colors duration-150">Simulateur ROI</a>
          </li>
          <li>
            <a href="/#case-studies" class="hover:text-slate-900 transition-colors duration-150">Études de Cas</a>
          </li>
          <li>
            <a href="/candidature" class="hover:text-slate-900 transition-colors duration-150">Tester l'éligibilité</a>
          </li>
          <li>
            <a href="/partenaires" class="hover:text-slate-900 transition-colors duration-150 font-semibold text-primary-neon">Recrutement Artisans (pSEO)</a>
          </li>
        </ul>
      </div>

      <!-- Links column 2 -->
      <div>
        <h4 class="font-heading text-xs font-bold text-slate-900 uppercase tracking-wider mb-4">Solutions</h4>
        <ul class="space-y-2.5 text-xs text-text-secondary">
          <li>
            <a href="/solutions" class="hover:text-slate-900 transition-colors duration-150 font-bold text-[#9A784E]">Hub Solutions (8 niches)</a>
          </li>
          <li>
            <a href="/solutions/toiture" class="hover:text-slate-900 transition-colors duration-150">Toiture & Couverture</a>
          </li>
          <li>
            <a href="/solutions/solaire" class="hover:text-slate-900 transition-colors duration-150">Solaire Photovoltaïque</a>
          </li>
          <li>
            <a href="/solutions/pac" class="hover:text-slate-900 transition-colors duration-150">Chauffage & PAC</a>
          </li>
          <li>
            <a href="/solutions/renovation" class="hover:text-slate-900 transition-colors duration-150">Rénovation Globale</a>
          </li>
          <li>
            <a href="/solutions/climatisation" class="hover:text-slate-900 transition-colors duration-150">Climatisation Réversible</a>
          </li>
          <li>
            <a href="/solutions/borne-recharge" class="hover:text-slate-900 transition-colors duration-150">Bornes de Recharge (IRVE)</a>
          </li>
          <li>
            <a href="/solutions/fenetres" class="hover:text-slate-900 transition-colors duration-150">Fenêtres & Menuiseries</a>
          </li>
          <li>
            <a href="/solutions/monte-escalier" class="hover:text-slate-900 transition-colors duration-150">Monte-Escalier PMR</a>
          </li>
        </ul>
      </div>

      <!-- Links column 3: Legal -->
      <div>
        <h4 class="font-heading text-xs font-bold text-slate-900 uppercase tracking-wider mb-4">Légal</h4>
        <ul class="space-y-2.5 text-xs text-text-secondary">
          <li>
            <a href="/mentions-legales" class="hover:text-slate-900 transition-colors duration-150">Mentions Légales</a>
          </li>
          <li>
            <a href="/confidentialite" class="hover:text-slate-900 transition-colors duration-150">Confidentialité</a>
          </li>
          <li>
            <a href="/conditions" class="hover:text-slate-900 transition-colors duration-150">Conditions (CGV)</a>
          </li>
        </ul>
      </div>

    </div>

    <!-- Divider -->
    <div class="border-t border-slate-200 my-10"></div>

    <!-- Bottom info -->
    <div class="flex flex-col sm:flex-row items-center justify-between text-[11px] text-text-secondary space-y-4 sm:space-y-0">
      <div>
        © 2026 Wade Studio. Tous droits réservés. Conçu pour les artisans ambitieux.
      </div>
      <div class="flex items-center space-x-1 font-mono">
        <span>Made with</span>
        <Heart class="h-3 w-3 text-red-500 fill-red-500 animate-pulse" />
        <span>for Premium Contractors.</span>
      </div>
    </div>

  </div>
</footer>
