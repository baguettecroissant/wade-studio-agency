---
// Hero component
import { ShieldCheck, Play } from '@lucide/astro';
---

<section class="relative overflow-hidden pt-10 pb-20 lg:pt-14 lg:pb-32 bg-[#FBF9F6]/30">
  <!-- Subtle Editorial Background Grid -->
  <div class="absolute inset-0 bg-[linear-gradient(to_right,rgba(15,23,42,0.02)_1px,transparent_1px),linear-gradient(to_bottom,rgba(15,23,42,0.02)_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_40%,#000_70%,transparent_100%)] pointer-events-none z-0"></div>



  <div class="container mx-auto max-w-4xl px-6 relative z-10 text-center flex flex-col items-center space-y-6 mt-1">
    <!-- Badge -->
    <div class="inline-flex items-center space-x-2 rounded-full border border-primary-neon/15 bg-primary-neon/5 px-3.5 py-1.5 backdrop-blur-sm">
      <ShieldCheck class="h-4.5 w-4.5 text-primary-neon" />
      <span class="font-mono text-[10px] font-bold text-primary-neon uppercase tracking-widest">Exclusivité Totale Artisans</span>
    </div>
    
    <!-- Main Hook -->
    <h1 class="font-heading text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl lg:text-7xl leading-[1.12] sm:leading-[1.12] max-w-3xl mx-auto">
      Arrêtez de partager vos clients.<br />
      <span class="gradient-text-editorial">Obtenez des chantiers exclusifs.</span>
    </h1>
    
    <!-- Sub-headline -->
    <p class="font-sans text-base sm:text-lg text-text-secondary leading-relaxed max-w-2xl mx-auto">
      Nous concevons des portails web locaux numéro 1 sur Google qui capturent des demandes de devis et vous les envoient en exclusivité. <span class="text-slate-900 font-bold">Zéro concurrence. 100% de réactivité.</span>
    </p>
    
    <!-- CTA & Sub-label -->
    <div class="flex flex-col items-center space-y-4 pt-4">
      <div class="flex flex-col sm:flex-row items-center gap-4">
        <div class="relative group">
          <a href="/candidature" class="relative inline-flex h-16 items-center justify-center rounded-2xl bg-primary-neon px-10 text-base font-bold text-white shadow-md transition-all duration-300 hover:bg-primary-neon/90 hover:scale-[1.01] active:scale-[0.99] border-none">
            Vérifier la disponibilité dans mon secteur →
          </a>
        </div>
        
        <button id="hero-watch-video-btn" class="inline-flex h-16 items-center justify-center rounded-2xl border border-slate-200 bg-white hover:bg-slate-50 px-8 text-base font-bold text-slate-900 shadow-sm transition-all duration-300 hover:scale-[1.01] active:scale-[0.99] cursor-pointer">
          <Play class="h-4.5 w-4.5 text-accent-violet fill-accent-violet/10 mr-2 shrink-0" />
          <span>Voir le fonctionnement en vidéo</span>
        </button>
      </div>
      <div class="flex flex-col items-center">
        <span class="font-mono text-xs font-bold text-slate-800 flex items-center space-x-1.5 justify-center">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent-violet opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-accent-violet"></span>
          </span>
          <span>Test gratuit & sans engagement</span>
        </span>
        <span class="text-xs text-text-secondary mt-1">Réponse instantanée — <a href="/partenaires" class="text-[#9A784E] font-bold hover:underline">Consulter les départements disponibles →</a></span>
      </div>
    </div>

    <!-- Trust markers -->
    <div class="pt-10 border-t border-slate-200 grid grid-cols-3 gap-8 w-full max-w-2xl mx-auto mt-8">
      <div>
        <span class="block font-heading text-3xl font-bold tracking-tight leading-none text-primary-neon" id="hero-count-leads">1,438</span>
        <span class="text-xs text-text-secondary mt-1.5 block">Chantiers distribués ce mois</span>
      </div>
      <div>
        <span class="block font-heading text-3xl font-bold tracking-tight leading-none text-accent-violet">0%</span>
        <span class="text-xs text-text-secondary mt-1.5 block">Partage de fiches clients</span>
      </div>
      <div>
        <span class="block font-heading text-3xl font-bold tracking-tight leading-none text-primary-neon">48h</span>
        <span class="text-xs text-text-secondary mt-1.5 block">Mise en place moyenne</span>
      </div>
    </div>
  </div>
</section>

<script>
  const totalLeadsCounter = document.getElementById('hero-count-leads');
  let totalLeads = 1438;

  function updateLeadCounter() {
    totalLeads += Math.floor(Math.random() * 2) + 1;
    if (totalLeadsCounter) {
      totalLeadsCounter.textContent = totalLeads.toLocaleString();
    }
  }

  // Increment lead counter slowly over time
  setInterval(updateLeadCounter, 4000);

  // Watch video button scrolling and auto-playing
  const watchVideoBtn = document.getElementById('hero-watch-video-btn');
  watchVideoBtn?.addEventListener('click', () => {
    const videoSection = document.getElementById('explainer-video');
    if (videoSection) {
      videoSection.scrollIntoView({ behavior: 'smooth' });
      
      // Attempt to autoplay after scrolling starts (or delay slightly to align with scroll)
      setTimeout(() => {
        const video = document.getElementById('explainer-video-player') as HTMLVideoElement;
        const overlay = document.getElementById('video-play-overlay');
        if (video) {
          video.play().then(() => {
            if (overlay) {
              overlay.classList.add('opacity-0', 'pointer-events-none');
            }
            video.controls = true;
          }).catch((err) => {
            console.log("Autoplay was blocked or failed:", err);
          });
        }
      }, 800); // 800ms corresponds roughly to the smooth scroll duration
    }
  });
</script>
